# Copy to .env.local and fill in. Every value here is optional — the site
# builds and runs without any of them, degrading gracefully.

# Canonical URL. Used for metadata, OG tags, sitemap and robots.
NEXT_PUBLIC_SITE_URL="https://divyeshkolli.vercel.app"

# GitHub personal access token (classic, no scopes needed for public data).
# Without it you get 60 API requests/hour per IP, and the contribution
# calendar falls back to a 90-day window built from the public events feed.
# With it: 5,000 requests/hour and the real 12-month contribution graph.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=""

# Resend API key, for the contact form. Without it the form validates the
# message, then hands the visitor a prefilled mailto: instead of dropping it.
# The message is delivered to the `email` in constants/site.ts, with the
# visitor's name as the sender and their address as reply-to.
# NOTE: with the default onboarding sender below, Resend only delivers to the
# email you signed up to Resend with. To receive at any address and use your
# own domain, verify a domain and set CONTACT_FROM to an address on it.
# https://resend.com/api-keys
RESEND_API_KEY=""

# Verified sender ADDRESS only (no display name — the visitor's name is used
# as the display name automatically). Defaults to Resend's shared onboarding
# address.
CONTACT_FROM="onboarding@resend.dev"

# Inbox that receives form submissions. Defaults to the public `email` in
# constants/site.ts. IMPORTANT: with the default onboarding sender, Resend only
# delivers to the address your Resend account was created with, so set this to
# that inbox. Once you verify a domain in Resend, this can be any address.
CONTACT_TO="your-resend-account-email@example.com"
